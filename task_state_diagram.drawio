<mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />

    <!-- Start node -->
    <mxCell id="s0" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="535" y="30" width="30" height="30" as="geometry" />
    </mxCell>

    <!-- States -->
    <mxCell id="s1" value="To Do" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="480" y="110" width="140" height="60" as="geometry" />
    </mxCell>
    <mxCell id="s2" value="In Progress" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="480" y="250" width="140" height="60" as="geometry" />
    </mxCell>
    <mxCell id="s3" value="Done" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="480" y="390" width="140" height="60" as="geometry" />
    </mxCell>
    <mxCell id="s4" value="Archived" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="480" y="530" width="140" height="60" as="geometry" />
    </mxCell>

    <!-- Start → To Do -->
    <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="s0" target="s1" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- To Do → In Progress -->
    <mxCell id="e2" value="Start work" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="s1" target="s2" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- In Progress → Done -->
    <mxCell id="e3" value="Mark complete" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="s2" target="s3" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Done → Archived -->
    <mxCell id="e4" value="Archive" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="s3" target="s4" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- To Do → Archived (right bypass) -->
    <mxCell id="e5" value="Archive" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitPerimeter=0;entryX=1;entryY=0.5;entryPerimeter=0;" edge="1" source="s1" target="s4" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="710" y="140" />
          <mxPoint x="710" y="560" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- In Progress → Archived (right bypass) -->
    <mxCell id="e6" value="Archive" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitPerimeter=0;entryX=1;entryY=0.5;entryPerimeter=0;" edge="1" source="s2" target="s4" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="690" y="280" />
          <mxPoint x="690" y="560" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- In Progress → To Do (left, reset) -->
    <mxCell id="e7" value="Reset" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="s2" target="s1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="410" y="280" />
          <mxPoint x="410" y="140" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Done → In Progress (left, reopen) -->
    <mxCell id="e8" value="Reopen" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="s3" target="s2" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="430" y="420" />
          <mxPoint x="430" y="280" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Archived → To Do (restore, far left) -->
    <mxCell id="e9" value="Restore" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="s4" target="s1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="370" y="560" />
          <mxPoint x="370" y="140" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Title label -->
    <mxCell id="title" value="Task State Diagram — Task Tracker" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="350" y="630" width="400" height="40" as="geometry" />
    </mxCell>
  </root>
</mxGraphModel>
